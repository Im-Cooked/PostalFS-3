<%- include('layout-top') %>

<style>
  .report-container {
    padding: 20px;
    max-width: 1400px;
    margin: 0 auto;
  }
  
  .report-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 30px;
    padding-bottom: 20px;
    border-bottom: 3px solid #e74c3c;
  }
  
  .report-title {
    font-size: 32px;
    font-weight: 700;
    color: #2c3e50;
    margin: 0;
  }
  
  .metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
  }
  
  .metric-card {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 25px;
    border-radius: 12px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.12);
    color: white;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .metric-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.18);
  }
  
  .metric-card.red {
    background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  }
  
  .metric-card.green {
    background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  }
  
  .metric-card.orange {
    background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
  }
  
  .metric-card.purple {
    background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  }
  
  .metric-label {
    font-size: 14px;
    opacity: 0.9;
    margin-bottom: 8px;
    font-weight: 500;
  }
  
  .metric-value {
    font-size: 36px;
    font-weight: 700;
    margin: 0;
  }
  
  .metric-subtitle {
    font-size: 12px;
    opacity: 0.85;
    margin-top: 5px;
  }
  
  .report-section {
    background: white;
    padding: 25px;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
    margin-bottom: 30px;
  }
  
  .section-title {
    font-size: 22px;
    font-weight: 600;
    color: #2c3e50;
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid #f0f0f0;
  }
  
  .status-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    margin-bottom: 20px;
  }
  
  .status-badge {
    padding: 10px 20px;
    border-radius: 8px;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  
  .status-badge.created { background: #e3f2fd; color: #1976d2; }
  .status-badge.ready { background: #fff3e0; color: #f57c00; }
  .status-badge.shipped { background: #e8f5e9; color: #388e3c; }
  .status-badge.delivered { background: #f3e5f5; color: #7b1fa2; }
  
  .two-column-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
  }
  
  @media (max-width: 968px) {
    .two-column-layout {
      grid-template-columns: 1fr;
    }
  }
  
  table {
    width: 100%;
    border-collapse: collapse;
  }
  
  table thead tr {
    background: #e74c3c;
    color: white;
  }
  
  table th {
    padding: 12px;
    text-align: left;
    font-weight: 600;
  }
  
  table td {
    padding: 12px;
    border-bottom: 1px solid #f0f0f0;
  }
  
  table tbody tr:hover {
    background: #f8f9fa;
  }
  
  .warning-box {
    background: #fff3cd;
    border-left: 4px solid #ffc107;
    padding: 15px;
    border-radius: 8px;
    margin-bottom: 20px;
  }
  
  .info-box {
    background: #d1ecf1;
    border-left: 4px solid #17a2b8;
    padding: 15px;
    border-radius: 8px;
    margin-bottom: 20px;
  }
  
  .chart-placeholder {
    height: 200px;
    background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6c757d;
    font-weight: 600;
  }
</style>

<div class="report-container">
  <div class="report-header">
    <h1 class="report-title">📊 Analytics & Reports</h1>
    <a href="/admin/dashboard" class="btn red">← Back to Dashboard</a>
  </div>

  <%
    const successRateNum = Number(stats && stats.successRate);
    const successRatePct = !isFinite(successRateNum)
      ? 0
      : (successRateNum > 1 ? successRateNum : successRateNum * 100);
  %>

  <!-- Key Metrics -->
  <div class="metrics-grid">
    <div class="metric-card">
      <div class="metric-label">💰 Total Revenue</div>
      <p class="metric-value">฿<%= stats.totalRevenuePaid ? stats.totalRevenuePaid.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) : '0.00' %></p>
      <div class="metric-subtitle">From paid orders</div>
    </div>
    
    <div class="metric-card red">
      <div class="metric-label">📦 Total Parcels</div>
      <p class="metric-value"><%= stats.totalParcels || 0 %></p>
      <div class="metric-subtitle">All time shipments</div>
    </div>
    
    <div class="metric-card green">
      <div class="metric-label">✅ Success Rate</div>
      <p class="metric-value"><%= successRatePct.toFixed(1) %>%</p>
      <div class="metric-subtitle"><%= stats.successCount || 0 %> of <%= stats.totalCount || 0 %> delivered</div>
    </div>
    
    <div class="metric-card orange">
      <div class="metric-label">👥 Total Customers</div>
      <p class="metric-value"><%= stats.totalCustomers || 0 %></p>
      <div class="metric-subtitle">Active users</div>
    </div>
    
    <div class="metric-card purple">
      <div class="metric-label">💵 Avg Shipping Cost</div>
      <p class="metric-value">฿<%= (stats.avgShippingCost || 0).toFixed(0) %></p>
      <div class="metric-subtitle">Per parcel average</div>
    </div>
    
    <div class="metric-card" style="background: linear-gradient(135deg, #ff9a56 0%, #ff6a00 100%);">
      <div class="metric-label">⚠️ Overdue Parcels</div>
      <p class="metric-value"><%= stats.overdueCount || 0 %></p>
      <div class="metric-subtitle">&gt;7 days pending</div>
    </div>
  </div>

  <!-- Status Breakdown -->
  <div class="report-section">
    <h3 class="section-title">📈 Parcel Status Overview</h3>
    <div class="status-badges">
      <% (stats.statusBreakdown || []).forEach(s => { %>
        <div class="status-badge <%= s.status.toLowerCase() %>">
          <span style="font-size: 20px;"><%= s.count %></span>
          <span><%= s.status %></span>
        </div>
      <% }) %>
    </div>
  </div>

  <!-- Two Column Layout -->
  <div class="two-column-layout">
    <!-- Payment Analysis -->
    <div class="report-section">
      <h3 class="section-title">💳 Revenue by Payment Method</h3>
      <% if (stats.revenueByMethod && stats.revenueByMethod.length > 0) { %>
        <table>
          <thead>
            <tr>
              <th>Payment Method</th>
              <th>Total Revenue</th>
            </tr>
          </thead>
          <tbody>
            <% stats.revenueByMethod.forEach(r => { %>
              <tr>
                <td><strong><%= r.payment_method %></strong></td>
                <td>฿<%= Number(r.total).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <p style="color: #6c757d; text-align: center; padding: 20px;">No payment data available</p>
      <% } %>
    </div>

    <!-- COD Outstanding -->
    <div class="report-section">
      <h3 class="section-title">💸 COD Outstanding</h3>
      <% if (stats.codOutstanding && stats.codOutstanding.length > 0) { %>
        <div class="warning-box">
          <strong>⚠️ Action Required:</strong> <%= stats.codOutstanding.length %> COD payment(s) pending collection
        </div>
        <table>
          <thead>
            <tr>
              <th>Payment ID</th>
              <th>Amount</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% stats.codOutstanding.forEach(o => { %>
              <tr>
                <td>#<%= o.payment_id %></td>
                <td>฿<%= Number(o.amount||0).toFixed(2) %></td>
                <td><span class="status-badge <%= o.status.toLowerCase() %>"><%= o.status %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="info-box">
          <strong>✅ All Clear:</strong> No outstanding COD payments
        </div>
      <% } %>
    </div>
  </div>

  <!-- Top Customers -->
  <div class="report-section">
    <h3 class="section-title">🏆 Top 10 Customers</h3>
    <% if (stats.topCustomers && stats.topCustomers.length > 0) { %>
      <table>
        <thead>
          <tr>
            <th>Rank</th>
            <th>Customer Name</th>
            <th>Parcels Sent</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% stats.topCustomers.forEach((c, index) => { %>
            <tr>
              <td><strong>#<%= index + 1 %></strong></td>
              <td><%= c.customer_name %></td>
              <td><span style="background: #e74c3c; color: white; padding: 4px 12px; border-radius: 12px; font-weight: 600;"><%= c.sentCount %></span></td>
              <td><a href="/admin/user/<%= c.customer_id %>" class="btn red" style="padding: 6px 12px; font-size: 14px;">View Details</a></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p style="color: #6c757d; text-align: center; padding: 20px;">No customer data available</p>
    <% } %>
  </div>

  <!-- Tracking Locations -->
  <div class="report-section">
    <h3 class="section-title">📍 Top Track Locations</h3>
    <% if (stats.trackLocations && stats.trackLocations.length > 0) { %>
      <table>
        <thead>
          <tr>
            <th>Location</th>
            <th>Update Count</th>
          </tr>
        </thead>
        <tbody>
          <% stats.trackLocations.forEach(l => { %>
            <tr>
              <td>📍 <%= l.location %></td>
              <td><%= l.count %> updates</td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p style="color: #6c757d; text-align: center; padding: 20px;">No tracking data available</p>
    <% } %>
  </div>

  <!-- Latest Parcels -->
  <div class="report-section">
    <h3 class="section-title">🕒 Latest 10 Parcels</h3>
    <% if (stats.latestParcels && stats.latestParcels.length > 0) { %>
      <table>
        <thead>
          <tr>
            <th>Parcel ID</th>
            <th>Sender</th>
            <th>Receiver</th>
            <th>Created Date</th>
          </tr>
        </thead>
        <tbody>
          <% stats.latestParcels.forEach(p => { %>
            <tr>
              <td><strong>#<%= p.parcel_id %></strong></td>
              <td><%= p.sender_name || '-' %></td>
              <td><%= p.receiver_name %></td>
              <td><%= new Date(p.created_at).toLocaleDateString('en-US', {year: 'numeric', month: 'short', day: 'numeric'}) %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    <% } else { %>
      <p style="color: #6c757d; text-align: center; padding: 20px;">No parcels found</p>
    <% } %>
  </div>

</div><!-- /.report-container -->

<%- include('layout-bottom') %>